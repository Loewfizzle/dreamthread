# Supabase configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
# Copy this file to .env.local and fill in your values (never commit .env.local)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
# Legacy / alternative name (also supported for compatibility):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL used for magic link redirects in emails (set to your production domain)
# This ensures magic links always point to https://dreamthread.app even during local development
NEXT_PUBLIC_SITE_URL=https://dreamthread.app

# For local development you can override this in .env.local if you want magic links to point to localhost
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Fal.ai API key for high-quality image generation (Flux models)
# Get your key at https://fal.ai/keys
FAL_KEY=your-fal-key-here

# OpenAI API key for Whisper transcription and dream reflections
OPENAI_API_KEY=your-openai-key-here
